# LLM API — any OpenAI-compatible endpoint
# Recommended: Alibaba Cloud DashScope (qwen-plus) or OpenAI
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Memory backend =====
# Which storage backend to use for the knowledge graph.
# Currently supported: supabase (see docs/memory-layer.md)
MEMORY_BACKEND=supabase

# ===== Boosted LLM (optional) =====
# Uncomment only if you want a separate faster/cheaper model for some calls.
# If unused, remove these lines entirely.
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here
